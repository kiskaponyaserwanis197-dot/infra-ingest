# 本地私有模型示例。适用于 Ollama / LM Studio / vLLM 等 OpenAI-compatible 本地服务。
LLM_API_KEY=local
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:14b
LLM_TIMEOUT=300
LLM_TEMPERATURE=0.2

LLM_CHUNK_CHAR_LIMIT=40000
LLM_CHUNK_OVERLAP=800

WHISPER_LANGUAGE=zh
WHISPER_BEAM_SIZE=5
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

OBSIDIAN_VAULT_PATH=/Users/you/Documents/Whisper转写笔记
TARGET_FOLDER=.
